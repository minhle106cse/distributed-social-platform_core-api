// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODULE: USER & PROFILE (Bounded Context: Identity & Graph)
// ============================================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?  @map("full_name")
  
  // Profile metrics
  trustScore Int      @default(100) @map("trust_score")
  avatarUrl  String?  @map("avatar_url")
  
  // GrowthGarden Specific
  shields    Int      @default(0) // Phao cứu sinh để bảo vệ streak
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  // Relations WITHIN this bounded context
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")

  @@index([email])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollowing", fields: [followerId], references: [id])
  following User @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}


// ============================================================================
// MODULE: SOCIAL (Bounded Context: Healing Feed Engine)
// ============================================================================

model Post {
  id        String   @id @default(uuid())
  authorId  String   @map("author_id") // Loose reference to User.id
  content   String   @db.Text
  
  // Optional links to Garden/Weather
  relatedSeedId   String?  @map("related_seed_id")
  relatedWeatherId String? @map("related_weather_id")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  // Relations WITHIN this bounded context
  comments PostComment[]
  reactions    PostReaction[]

  @@index([authorId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id") // Loose reference to User.id
  content   String   @db.Text
  
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  post Post @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([authorId])
}

enum VibeType {
  WATER_DROP    // Gửi nước
  SUNLIGHT      // Gửi nắng
  SPARKLE       // Lấp lánh/Cổ vũ
  HUG           // Ôm (Đồng cảm khi thất bại)
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id") // Loose reference to User.id
  type      VibeType @default(SPARKLE)
  
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id])

  @@unique([postId, userId])
  @@map("post_reactions")
}


// ============================================================================
// MODULE: GARDEN (Bounded Context: Goal & Habit Planting)
// ============================================================================

enum SeedState {
  SEED      // Hạt giống mới trồng
  SPROUT    // Nảy mầm (Đã tưới vài lần)
  TREE      // Đang phát triển tốt
  BLOOMING  // Đơm hoa (Đạt mốc lớn)
  DORMANT   // Nghỉ ngơi (User chọn tạm dừng hoặc lỡ 1 ngày)
}

model HabitSeed {
  id          String    @id @default(uuid())
  ownerId     String    @map("owner_id") // Loose reference to User.id
  title       String
  description String?
  state       SeedState @default(SEED)
  
  // Streaks & Stats
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  waterCount    Int       @default(0) @map("water_count")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wateringLogs WateringLog[]

  @@index([ownerId])
}

model WateringLog {
  id        String   @id @default(uuid())
  seedId    String   @map("seed_id")
  ownerId   String   @map("owner_id") // Loose reference to User.id
  note      String?
  
  wateredAt DateTime @default(now()) @map("watered_at")

  seed HabitSeed @relation(fields: [seedId], references: [id])

  @@index([seedId])
  @@index([ownerId])
}

// ============================================================================
// MODULE: WEATHER (Bounded Context: Emotion Tracker)
// ============================================================================

enum WeatherCondition {
  SUNNY       // Vui vẻ, tích cực
  RAINY       // Buồn nhẹ, mệt mỏi
  STORMY      // Tức giận, stress
  CLOUDY      // Trống rỗng, bình thường
  RAINBOW     // Cực kỳ hạnh phúc
}

model WeatherLog {
  id        String           @id @default(uuid())
  ownerId   String           @map("owner_id") // Loose reference to User.id
  condition WeatherCondition
  intensity Int              @default(5) // 1-10
  note      String?
  
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerId])
}

// ============================================================================
// MODULE: FINANCE (Bounded Context: Personal Expense Tracker - Phase 2)
// ============================================================================

model Expense {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id") // Loose reference to User.id
  amount      BigInt   // Storing cents to avoid float issues
  currency    String   @default("VND")
  category    String
  description String?
  date        DateTime
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([ownerId, date])
}


// ============================================================================
// MODULE: WALLET & COMPASSION EXCHANGE (Bounded Context: Micro-Bounty)
// ============================================================================

model Wallet {
  id        String   @id @default(uuid())
  ownerId   String   @unique @map("owner_id") // Loose reference to User.id
  balance   BigInt   @default(100) // Khởi tạo có sẵn 100 Karma
  currency  String   @default("KARMA")
  
  // Optimistic Locking version
  version   Int      @default(1)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations WITHIN this bounded context
  transactions Transaction[]
}

enum TransactionStatus {
  PENDING    // Escrow: Đang giữ tiền (chờ người kia giúp)
  COMPLETED  // Hoàn thành: Tiền đã chuyển vào ví
  REFUNDED   // Hoàn trả: Giao kèo thất bại, tiền về lại ví
}

model Transaction {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  amount      BigInt   // Positive for credit, negative for debit
  type        String   // DEPOSIT, WITHDRAW, BOUNTY_ESCROW, BOUNTY_PAYOUT
  status      TransactionStatus @default(COMPLETED)
  referenceId String?  @map("reference_id") // ID của bài Post nhờ vả
  description String?
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
}

// ============================================================================
// READ MODELS (CQRS)
// ============================================================================

model PostReadModel {
  id            String   @id // Cùng ID với Post gốc
  authorId      String   @map("author_id")
  content       String   @db.Text
  
  reactionCount Int      @default(0) @map("reaction_count")
  commentCount  Int      @default(0) @map("comment_count")
  
  createdAt     DateTime @map("created_at")
  updatedAt     DateTime @map("updated_at")

  @@index([authorId])
  @@map("post_read_models")
}
